# -------------------------------------------------------------
# 1. LLM CONFIGURATION (OLLAMA LOCAL)
# -------------------------------------------------------------
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5-coder:1.5b             # The model you downloaded via Ollama
OLLAMA_HOST=http://localhost:11434       # Local Ollama daemon endpoint

# -------------------------------------------------------------
# 2. GITHUB INTEGRATION
# -------------------------------------------------------------
GITHUB_TOKEN=your_github_personal_access_token_here
GITHUB_REPO=your_username/your_repo_name

# -------------------------------------------------------------
# 3. SMTP EMAIL NOTIFICATION CONFIGURATION
# -------------------------------------------------------------
SMTP_HOST=smtp.gmail.com                 # Gmail SMTP server host
SMTP_PORT=587                            # Gmail port for TLS
SMTP_USERNAME=your_email@gmail.com       # Your Gmail address
SMTP_PASSWORD=your_google_app_password   # The 16-character Google App Password (WITHOUT SPACES)
SENDER_EMAIL=your_email@gmail.com        # The sender email address
RECEIVER_EMAIL=your_target_inbox@gmail.com      # Your target inbox (where alerts should land)
